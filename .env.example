# ============================================
# 🐦 灵雀 LingQue 配置文件 (P6 版)
# 复制为 .env 并填入你的配置
# ============================================

# ---------- LLM 配置 ----------
# 默认模型（可选: deepseek / doubao / kimi / minimax / glm）
# 运行中可用 /model 命令切换，不用改这里
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
#DEEPSEEK_API_KEY=xxx
#DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# ANTHROPIC_API_KEY=sk-ant-xxx
# OPENAI_API_KEY=sk-xxx


# ---------- 豆包 (Doubao) 配置 ----------
# 豆包 API Key (火山引擎)
# DOUBAO_API_KEY=
# 豆包 API 地址 (默认即可)
# DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# 豆包模型 ID
# DOUBAO_MODEL=doubao-seed-2-0-pro-260215

# ---------- 自定义 OpenAI 兼容模型 ----------
# 支持任意 OpenAI 兼容 API，格式: LLM_PROVIDER_{名称}=base_url|api_key|model[|temperature[|extra_json]]
# 名称会自动转为小写作为 provider 标识，配好后可设 LLM_PROVIDER=名称 作为默认
# 也可在飞书中通过 /model 命令动态切换（/model 查看列表，/model 名称 切换）
# temperature 可选，某些模型强制要求固定值时使用
# extra_json 可选，JSON 格式的额外请求参数
# ⚠️ 注意: 同名只能保留一个！想同时用思考/快速两种模式，必须用不同名称
#
# ---------- 通义千问 (阿里云) ----------
# LLM_PROVIDER_QWEN=https://dashscope.aliyuncs.com/compatible-mode/v1|sk-xxx|qwen-max
#
# ---------- 智谱 GLM-5-Turbo ----------
# 思考模式（/model glm）:
# LLM_PROVIDER_GLM=https://open.bigmodel.cn/api/paas/v4|xxx.yyy|glm-5-turbo|1|{"thinking":{"type":"enabled"}}
# 快速模式（/model glmfast）:
# LLM_PROVIDER_GLMFAST=https://open.bigmodel.cn/api/paas/v4|xxx.yyy|glm-5-turbo
#
# ---------- 月之暗面 Kimi ----------
# 思考模式（/model kimi，temperature 必须为 1）:
# LLM_PROVIDER_KIMI=https://api.moonshot.cn/v1|sk-xxx|kimi-k2.5|1
# 快速模式（/model kimifast，禁用思考）:
# LLM_PROVIDER_KIMIFAST=https://api.moonshot.cn/v1|sk-xxx|kimi-k2.5||{"thinking":{"type":"disabled"}}
#
# ---------- MiniMax ----------
# 思考模式（/model minimax，temperature 建议 1）:
# LLM_PROVIDER_MINIMAX=https://api.minimaxi.com/v1|sk-xxx|MiniMax-M2.5|1|{"reasoning_split":true}
# 极速版（/model mmfast，约 100 TPS）:
# LLM_PROVIDER_MMFAST=https://api.minimaxi.com/v1|sk-xxx|MiniMax-M2.5-highspeed|1|{"reasoning_split":true}
#
# ---------- 零一万物 Yi ----------
# LLM_PROVIDER_YI=https://api.lingyiwanwu.com/v1|sk-xxx|yi-large
#
# ---------- 本地 Ollama ----------
# LLM_PROVIDER_OLLAMA=http://localhost:11434/v1|ollama|llama3

# ---------- 通道配置 ----------
# 多通道并行: 逗号分隔, 如 cli,feishu,dingtalk
CHANNELS=cli

# ---------- 飞书配置 ----------
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
# 连接模式: webhook (需要公网IP+端口) 或 websocket (长连接，无需公网IP)
# 长连接模式需在飞书开放平台 → 事件与回调 → 选择"使用长连接接收事件"
FEISHU_MODE=webhook
# 安全加固: 用户白名单 (逗号分隔的 open_id，空则允许所有人)
# 获取方式: 飞书开发者后台 → 事件日志里可以看到发送者的 open_id
FEISHU_ALLOWED_USERS=
# 机器人自己的 open_id (群聊 @ 判断用)
FEISHU_BOT_OPEN_ID=

# ---------- 钉钉配置 ----------
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=

# ---------- 邮件配置 ----------
EMAIL_IMAP_HOST=imap.qq.com
EMAIL_IMAP_PORT=993
EMAIL_SMTP_HOST=smtp.qq.com
EMAIL_SMTP_PORT=465
EMAIL_USERNAME=your@qq.com
EMAIL_PASSWORD=your_app_password

# ---------- P2: 邮件监控 ----------
# 是否启用邮件监控（新邮件主动通知）
EMAIL_MONITOR_ENABLED=false
# 检查间隔（秒）
EMAIL_MONITOR_INTERVAL=300
# 重要发件人（逗号分隔，来自这些发件人的邮件会主动通知）
EMAIL_IMPORTANT_SENDERS=boss@company.com,urgent@client.com
# 重要关键词（逗号分隔，标题包含这些关键词的邮件会主动通知）
EMAIL_IMPORTANT_KEYWORDS=紧急,重要,URGENT

# ---------- P2: 定时任务调度器 ----------
# 是否启用调度器
SCHEDULER_ENABLED=false
# 每日摘要 Cron 表达式 (默认每天早上8点)
DAILY_SUMMARY_CRON=0 8 * * *
# 是否启用每日摘要推送
DAILY_SUMMARY_ENABLED=false

# ---------- P2: 外部 Webhook ----------
# 是否启用外部 Webhook 接入
WEBHOOK_ENABLED=false
# GitHub Webhook Secret (用于验证请求)
GITHUB_WEBHOOK_SECRET=
# Sentry Webhook Secret
SENTRY_WEBHOOK_SECRET=

# ---------- Agent 超时配置 ----------
# 总任务超时（秒），整个 Agent 循环的硬限制
AGENT_TASK_TIMEOUT=600
# LLM 单次响应超时（秒），防止 API 卡住不返回
AGENT_LLM_TIMEOUT=120
# 默认工具执行超时（秒）
AGENT_TOOL_TIMEOUT=120
# 单段最大循环轮次（LLM→工具→LLM 的回合数上限）
AGENT_MAX_LOOPS=25
# 长任务自动续航次数（0=禁用，到达 max_loops 后自动压缩上下文继续，无需用户说"继续"）
# 总步数上限 = max_loops × (1 + auto_continue)，默认 25×3=75 步
AGENT_AUTO_CONTINUE=2
# LLM 单次最大输出 token 数（0=不限制，按模型自身上限输出；设正整数则显式限制）
# 默认 0 即可，模型支持多少就输出多少，不会截断
# AGENT_MAX_OUTPUT_TOKENS=0
# 工具返回结果最大字符数（0=不限制；默认 15000）
# 防止单次工具返回过大撑爆上下文，一般不用改
# AGENT_MAX_TOOL_RESULT_CHARS=15000
# 长耗时工具的超时覆盖（格式: 工具名:秒数，逗号分隔）
# 例如浏览器操作和代码执行给更长时间
# AGENT_TOOL_TIMEOUT_OVERRIDES=browser_open:180,run_python:300,sandbox_python:300

# ---------- 安全配置 ----------
REQUIRE_CONFIRMATION=true
MAX_TOOL_LOOPS=25
# 允许操作的目录 (逗号分隔)
ALLOWED_PATHS=./workspaces

# ---------- 会话配置 ----------
# 会话空闲超时（分钟），超过后自动压缩上下文（保留摘要，用户回来能接着聊）
# 默认 480 = 8小时，设为 0 可禁用空闲超时
SESSION_IDLE_TIMEOUT=480
# 每日重置时刻（小时，24小时制），跨过此时间完全清空会话（每天一个干净起点）
SESSION_DAILY_RESET_HOUR=4

# ---------- 存储 ----------
MEMORY_DIR=./memory
WORKSPACE_DIR=./workspaces

# ---------- 日志 ----------
LOG_LEVEL=INFO

# ==================== 技能移植器 ====================
# GitHub Token（可选，提高 API 请求限额，建议配置）
# 创建地址: https://github.com/settings/tokens (只需 public_repo 权限)
GITHUB_TOKEN=

# ==================== P3: 记忆增强 ====================
# 向量记忆库配置
# 嵌入模型（多语言支持，首次运行会自动下载）
# EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# ==================== P3: Docker 沙箱 ====================
# 沙箱内存限制
# SANDBOX_MEMORY_LIMIT=256m
# 沙箱 CPU 配额（百分比）
# SANDBOX_CPU_QUOTA=50
# 沙箱执行超时（秒）
# SANDBOX_TIMEOUT=30

# ==================== P3: 浏览器自动化 ====================
# 启动模式（默认 auto，一般不需要改）:
#   auto    = 全自动（推荐）：尝试附着已有 Chrome → 启动系统 Chrome → 内置 Chromium
#   builtin = 使用 Playwright 内置 Chromium（最兼容但无法绕过反爬）
# auto 模式下完全零配置：
#   - 如果你的 Chrome 开了远程调试，灵雀会自动附着（复用登录态）
#   - 如果没开，灵雀会自动启动一个独立 Chrome（不影响你正在用的浏览器）
#   - 都失败就用内置浏览器
# 想让灵雀复用你的 Chrome 登录态？在 Chrome 开启远程调试：
#   方法1: 打开 chrome://inspect → 勾选 "Allow remote debugging"
#   方法2: Chrome 快捷方式 → 属性 → 目标末尾加 --remote-debugging-port=9222
# BROWSER_MODE=auto
# CDP 调试端口（端口被占会自动选下一个空闲端口）
# BROWSER_CDP_PORT=9222
# 手动指定浏览器可执行文件路径（留空自动检测）
# BROWSER_EXECUTABLE_PATH=
# 是否无头模式（调试登录时建议 false 可以看到浏览器界面）
# BROWSER_HEADLESS=true
# 浏览器视口大小
# BROWSER_VIEWPORT=1280,720
# 下载目录
# BROWSER_DOWNLOADS_DIR=./downloads
# Set-of-Mark 视觉标注（在截图上标记元素编号，帮助 LLM 理解布局）
# 需要 LLM 支持视觉输入，默认开启
# BROWSER_SOM_ENABLED=true
# 多策略自愈定位（元素变化时自动尝试多种定位策略恢复）
# BROWSER_SELFHEAL_ENABLED=true

# ==================== Agent 上下文窗口 ====================
# 最大上下文消息条数（默认 80）
# AGENT_MAX_CONTEXT_MESSAGES=80
# 最大上下文 token 数（默认 64000）
# AGENT_MAX_CONTEXT_TOKENS=64000

# ==================== MCP 协议支持 ====================
# MCP 服务器配置（格式: name:/path/to/cmd arg1 arg2,name2:/path/to/cmd2）
# 例如: filesystem:npx -y @modelcontextprotocol/server-filesystem /tmp
# bb-browser: 用你真实浏览器操作 36 个平台（需先 npm install -g bb-browser + 安装 Chrome 扩展）
# MCP_SERVERS=bb-browser:npx -y bb-browser --mcp
